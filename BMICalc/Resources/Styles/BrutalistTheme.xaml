<?xml version="1.0" encoding="UTF-8"?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════
         COLOUR PALETTE — CONCRETE BRUTALISM
    ═══════════════════════════════════════════════════════ -->
    <Color x:Key="BackgroundColor">#111111</Color>
    <Color x:Key="SurfaceColor">#1E1E1E</Color>
    <Color x:Key="SurfaceLiftColor">#272727</Color>
    <Color x:Key="BorderColor">#3C3C3C</Color>
    <Color x:Key="BorderHeavyColor">#5A5A5A</Color>
    <Color x:Key="TextPrimary">#F0EDE8</Color>
    <Color x:Key="TextMuted">#888880</Color>
    <Color x:Key="AccentColor">#F5B800</Color>
    <Color x:Key="AccentDark">#C99000</Color>
    <Color x:Key="DangerColor">#FF4C4C</Color>

    <!-- ═══════════════════════════════════════════════════════
         TYPOGRAPHY
    ═══════════════════════════════════════════════════════ -->
    <!-- Big Shoulders Display Black  → display / numbers  -->
    <!-- Chakra Petch                 → labels / body       -->

    <Style x:Key="DisplayFont" TargetType="Label">
        <Setter Property="FontFamily"   Value="BigShoulders-Black"/>
        <Setter Property="TextColor"    Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize"     Value="72"/>
        <Setter Property="CharacterSpacing" Value="2"/>
    </Style>

    <Style x:Key="HeaderFont" TargetType="Label">
        <Setter Property="FontFamily"   Value="BigShoulders-Black"/>
        <Setter Property="TextColor"    Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize"     Value="42"/>
        <Setter Property="CharacterSpacing" Value="4"/>
    </Style>

    <Style x:Key="SubheaderFont" TargetType="Label">
        <Setter Property="FontFamily"   Value="BigShoulders-Black"/>
        <Setter Property="TextColor"    Value="{StaticResource AccentColor}"/>
        <Setter Property="FontSize"     Value="16"/>
        <Setter Property="CharacterSpacing" Value="6"/>
    </Style>

    <Style x:Key="BodyFont" TargetType="Label">
        <Setter Property="FontFamily"   Value="ChakraPetch-Regular"/>
        <Setter Property="TextColor"    Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="CharacterSpacing" Value="2"/>
    </Style>

    <Style x:Key="MutedLabel" TargetType="Label">
        <Setter Property="FontFamily"   Value="ChakraPetch-Regular"/>
        <Setter Property="TextColor"    Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"     Value="10"/>
        <Setter Property="CharacterSpacing" Value="3"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         ENTRY STYLE
    ═══════════════════════════════════════════════════════ -->
    <Style x:Key="BrutalistEntry" TargetType="Entry">
        <Setter Property="FontFamily"       Value="ChakraPetch-Regular"/>
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource BorderHeavyColor}"/>
        <Setter Property="BackgroundColor"  Value="Transparent"/>
        <Setter Property="FontSize"         Value="18"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="Keyboard"         Value="Numeric"/>
        <Setter Property="ReturnType"       Value="Next"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         BUTTON STYLES
    ═══════════════════════════════════════════════════════ -->
    <Style x:Key="CalculateButton" TargetType="Button">
        <Setter Property="FontFamily"       Value="BigShoulders-Black"/>
        <Setter Property="FontSize"         Value="22"/>
        <Setter Property="CharacterSpacing" Value="6"/>
        <Setter Property="TextColor"        Value="#111111"/>
        <Setter Property="BackgroundColor"  Value="{StaticResource AccentColor}"/>
        <Setter Property="CornerRadius"     Value="0"/>
        <Setter Property="HeightRequest"    Value="58"/>
        <Setter Property="Margin"           Value="0"/>
        <Setter Property="Padding"          Value="0"/>
    </Style>

    <Style x:Key="ToggleButtonActive" TargetType="Button">
        <Setter Property="FontFamily"       Value="BigShoulders-Black"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="CharacterSpacing" Value="4"/>
        <Setter Property="TextColor"        Value="#111111"/>
        <Setter Property="BackgroundColor"  Value="{StaticResource AccentColor}"/>
        <Setter Property="CornerRadius"     Value="0"/>
        <Setter Property="HeightRequest"    Value="40"/>
        <Setter Property="Padding"          Value="0"/>
    </Style>

    <Style x:Key="ToggleButtonInactive" TargetType="Button">
        <Setter Property="FontFamily"       Value="BigShoulders-Black"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="CharacterSpacing" Value="4"/>
        <Setter Property="TextColor"        Value="{StaticResource TextMuted}"/>
        <Setter Property="BackgroundColor"  Value="{StaticResource SurfaceColor}"/>
        <Setter Property="CornerRadius"     Value="0"/>
        <Setter Property="HeightRequest"    Value="40"/>
        <Setter Property="Padding"          Value="0"/>
    </Style>

</ResourceDictionary>
